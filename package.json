{
  "name": "loan-risk-analyzer",
  "private": true,
  "packageManager": "pnpm@10.11.0",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm --filter @loan-risk/http-api dev",
    "typecheck": "pnpm -r exec tsc --noEmit",
    "clean": "pnpm -r exec rimraf dist",
    "test:core": "pnpm --filter @loan-risk/core exec ts-node tests/test.ts",
    "test:hooks": "pnpm --filter @loan-risk/core exec ts-node tests/hooks.test.ts",
    "test:plugin": "pnpm --filter @loan-risk/core exec ts-node tests/plugin.test.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.5",
    "rimraf": "^6.0.1",
    "ts-node": "^10.9.2",
    "turbo": "^2.0.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5"
  }
}