{
  "extends": "../../tsconfig.base.json",

  "compilerOptions": {
    "rootDir": ".",

    "outDir": "dist",

    "declaration": true,

    "module": "CommonJS",

    "target": "ES2020",

    "moduleResolution": "Node",

    "esModuleInterop": true,

    "strict": true,

    "skipLibCheck": true,

    "ignoreDeprecations": "5.0"
  },

  "include": [
    "src",
    "tests/test.ts",
    "tests/hooks.test.ts",
    "tests/plugin.test.ts",
    "tests/fraud.test.ts",
    "check.ts",
    "tests/performance.test.ts"
  ]
}
