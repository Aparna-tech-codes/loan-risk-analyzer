{
  "extends": "../../tsconfig.base.json",

  "compilerOptions": {
    "rootDir": "src",

    "outDir": "dist",

    "module": "CommonJS",

    "target": "ES2020",

    "moduleResolution": "node",

    "esModuleInterop": true,

    "strict": true,

    "skipLibCheck": true,

    "composite": true
  },

  "include": ["src"],

  "exclude": [
    "dist",
    "node_modules"
  ],

  "references": [
    {
      "path": "../core"
    },
    {
      "path": "../logger"
    }
  ]
}