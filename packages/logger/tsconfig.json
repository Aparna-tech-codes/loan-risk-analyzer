{
  "extends": "../../tsconfig.base.json",

  "compilerOptions": {
    "rootDir": "src",

    "outDir": "dist",

    "declaration": true,

    "module": "CommonJS",

    "target": "ES2020",

    "moduleResolution": "node",

    "esModuleInterop": true,

    "strict": true,

    "skipLibCheck": true,

    "composite": true
  },

  "include": ["src"],

  "exclude": [
    "dist",
    "node_modules",
    "tests"
  ]
}