{
  "name": "@loan-risk/logger",
  "version": "1.0.1",

  "description": "Reusable TypeScript logger package for the loan risk analyzer ecosystem",

  "license": "MIT",

  "author": "Aparna Nikam",

  "homepage": "https://github.com/Aparna-tech-codes/loan-risk-analyzer",

  "repository": {
    "type": "git",
