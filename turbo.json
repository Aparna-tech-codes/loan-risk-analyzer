{
  "$schema": "https://turbo.build/schema.json",

  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [
        "dist/**",
        "*.tsbuildinfo"
      ]
    },

    "typecheck": {
      "dependsOn": ["^build"]
    },

    "lint": {
      "outputs": []
    },

    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}